@startuml
title Chapter 3 · QueryEngine Turn Flow

skinparam backgroundColor #FEFEFE
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam shadowing false
skinparam dpi 135
skinparam ranksep 34
skinparam nodesep 26
skinparam defaultFontName Georgia
skinparam defaultFontSize 15
skinparam TitleFontSize 20
skinparam NoteFontSize 14
skinparam ArrowFontSize 13
skinparam TitleFontColor #161616
skinparam activity {
  BackgroundColor #F2E9D9
  BorderColor #1D1D1D
  FontColor #161616
  ArrowColor #5E5A53
  StartColor #8C2721
  EndColor #161616
  DiamondBackgroundColor #F5EBDD
  DiamondBorderColor #8C2721
}
skinparam note {
  BackgroundColor #F5EBDD
  BorderColor #8C2721
  FontColor #7B1E1E
}

start
:submitMessage(...);
:Normalize input and attachments;
:Build system / user / tool context;
:Invoke query(...);
:Consume streamed query events;
:Persist transcript and replay markers;
:Update SDK-facing session state;
stop

note right
  QueryEngine wraps one turn
  around the lower-level
  query loop.
end note

@enduml
