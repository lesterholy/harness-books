@startuml
title Chapter 6 · Recovery Decision Paths

skinparam backgroundColor #FEFEFE
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam shadowing false
skinparam dpi 135
skinparam ranksep 34
skinparam nodesep 26
skinparam defaultFontName Georgia
skinparam defaultFontSize 15
skinparam TitleFontSize 20
skinparam NoteFontSize 14
skinparam ArrowFontSize 13
skinparam TitleFontColor #161616
skinparam activity {
  BackgroundColor #F2E9D9
  BorderColor #1D1D1D
  FontColor #161616
  ArrowColor #5E5A53
  StartColor #8C2721
  EndColor #161616
  DiamondBackgroundColor #F5EBDD
  DiamondBorderColor #8C2721
}
skinparam note {
  BackgroundColor #F5EBDD
  BorderColor #8C2721
  FontColor #7B1E1E
}

start
:Recoverable failure observed;

if (prompt too long?) then (yes)
  :Drain staged collapse;
  :Attempt reactive compact once;
elseif (max_output_tokens?) then (yes)
  :Raise output cap if cheap;
  :Otherwise continue directly\nwithout recap;
else (other)
  :Classify API retry / abort /\nunrecoverable error;
endif

if (budget exhausted or guard trips?) then (stop)
  :Surface error;
else (continue)
  :Prepare retry or compact result;
  :Re-enter query loop;
endif
stop

note right
  Recovery is layered:
  cheaper local fixes first,
  heavier summarization later.
end note

@enduml
